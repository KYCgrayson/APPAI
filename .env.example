# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Transactional email for native order notifications
RESEND_API_KEY=""
APPAI_EMAIL_FROM="AppAI Orders <orders@yourdomain.com>"

# Private Vercel Blob store for native app documents. This must be a token for
# a Blob store configured with private access; do not reuse the public upload
# store token.
PRIVATE_BLOB_READ_WRITE_TOKEN=""
SIMPLESHOP_PRIVATE_ASSET_MAX_FILE_BYTES="2097152"
SIMPLESHOP_PRIVATE_ASSET_ORG_LIMIT_BYTES="104857600"
SIMPLESHOP_PRIVATE_ASSET_LARGE_FILE_BYTES="524288"
