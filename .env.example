# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Transactional email for native order notifications
RESEND_API_KEY=""
APPAI_EMAIL_FROM="AppAI Orders <orders@yourdomain.com>"

# Optional static credential for local or non-Vercel private Blob access.
# Vercel deployments use the connected store's short-lived OIDC identity and
# auto-managed BLOB_STORE_ID instead; do not reuse a public store token.
PRIVATE_BLOB_READ_WRITE_TOKEN=""
PRIVATE_ASSET_MAX_FILE_BYTES="2097152"
PRIVATE_ASSET_ORG_LIMIT_BYTES="104857600"
PRIVATE_ASSET_LARGE_FILE_BYTES="524288"
