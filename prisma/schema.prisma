generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ===== NextAuth.js Models =====

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("USER") // USER | ADMIN

  accounts Account[]
  sessions Session[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===== Business Models =====

model Organization {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text
  logoUrl     String?
  website     String?
  email       String?

  plan String @default("FREE")

  users               User[]
  apiKeys             ApiKey[]
  pages               HostedPage[]
  apps                App[]
  organizationApps    OrganizationApp[]
  privateAssets       PrivateAsset[]
  usageEvents         UsageEvent[]
  simpleshopSequences SimpleshopSequence[]
  customers           Customer[]
  jobSites            JobSite[]
  jobSiteAliases      JobSiteAlias[]
  jobSiteMonthCodes   JobSiteMonthCode[]
  itemCategories      ItemCategory[]
  items               Item[]
  itemAliases         ItemAlias[]
  itemUnits           ItemUnit[]
  priceRecords        PriceRecord[]
  customerContacts    CustomerContact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id             String       @id @default(cuid())
  keyHash        String       @unique
  keyPrefix      String
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)

  createdAt DateTime @default(now())
}

model HostedPage {
  id             String       @id @default(cuid())
  slug           String
  locale         String       @default("en") // BCP 47: "en", "ja", "zh-CN", "ko", etc.
  isDefault      Boolean      @default(false) // Only one locale per slug should be true
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  template   String  @default("APP_LANDING")
  title      String
  tagline    String?
  heroImage  String?
  headerLogo String?
  content    Json

  privacyPolicy  String? @db.Text
  termsOfService String? @db.Text

  metaTitle       String?
  metaDescription String?
  ogImage         String?
  canonicalUrl    String? // Override canonical URL; lets apps with own domain reuse template while keeping SEO on main site

  customCss           String? @db.Text
  themeColor          String? @default("#000000")
  themeColorSecondary String?
  fontFamily          String?
  darkMode            Boolean @default(false)
  isPublished         Boolean @default(false)

  customDomain String? @unique

  // Multi-page sites: parentSlug=null means root page; otherwise this is a child
  // page of (organizationId, parentSlug). Only one level of nesting is allowed —
  // child pages cannot themselves have children. URL: /p/{parentSlug}/{slug}.
  parentSlug String?

  // Nav controls — apply to both root and child pages. hideFromNav lets a page
  // exist without appearing in site navigation (Privacy, Terms, compliance-only
  // pages). navOrder controls position when non-null; ties break on createdAt.
  hideFromNav Boolean @default(false)
  navOrder    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, locale])
  @@index([organizationId, parentSlug, slug])
}

// RFC 8628 OAuth Device Authorization Grant
model DeviceCode {
  id             String    @id @default(cuid())
  deviceCode     String    @unique // High-entropy (256-bit), used by CLI to poll
  userCode       String // Short code "WDJB-MJHT", shown to user
  status         String    @default("pending") // pending | authorized | denied | expired | consumed
  apiKey         String? // Plaintext key, cleared after consumed
  organizationId String?
  interval       Int       @default(5) // Polling interval in seconds, increases on slow_down
  lastPolledAt   DateTime? // Server-side rate limiting for polling
  expiresAt      DateTime
  createdAt      DateTime  @default(now())
}

model PageView {
  id        String   @id @default(cuid())
  pageId    String
  slug      String
  locale    String
  orgId     String
  ipHash    String
  country   String?
  referrer  String?  @db.Text
  createdAt DateTime @default(now())

  @@index([pageId, createdAt])
  @@index([orgId, createdAt])
  @@index([createdAt])
}

model App {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  tagline     String
  description String   @db.Text
  category    String   @default("OTHER")
  tags        String[] @default([])

  url        String?
  repoUrl    String?
  iosUrl     String?
  androidUrl String?

  logoUrl     String?
  screenshots String[] @default([])

  hostedPageSlug String? @unique
  appType        String? @unique
  runtimePath    String?

  isApproved Boolean @default(false)
  isFeatured Boolean @default(false)

  releases AppRelease[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A code-approved native app enabled for one Organization. Business data
// remains in app-owned tables; config is limited to small non-accounting
// settings validated by the native app registry.
model OrganizationApp {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appType        String
  status         String       @default("ACTIVE") // ACTIVE | SUSPENDED
  config         Json?

  capabilityGrants AppCapabilityGrant[]
  launchCodes      AppLaunchCode[]
  runtimeSessions  AppRuntimeSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, appType])
  @@index([appType, status])
  @@index([organizationId, status])
}

// Versioned, immutable release metadata submitted by an app's owning
// Organization. The manifest describes the isolated artifact; executable app
// code never becomes part of the AppAI Next.js process.
model AppRelease {
  id             String  @id @default(cuid())
  appId          String
  app            App     @relation(fields: [appId], references: [id], onDelete: Cascade)
  version        String
  manifest       Json
  sourceRevision String?
  artifactDigest String?
  status         String  @default("PENDING") // PENDING | APPROVED | REJECTED | RETIRED

  deployments AppDeployment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([appId, version])
  @@index([appId, status, createdAt])
}

// Platform-controlled deployment record. runtimeBaseUrl is operational data
// stored in PostgreSQL and is never accepted from an app launch request.
model AppDeployment {
  id              String     @id @default(cuid())
  appReleaseId    String
  appRelease      AppRelease @relation(fields: [appReleaseId], references: [id], onDelete: Cascade)
  environment     String     @default("PRODUCTION")
  runtimeBaseUrl  String     @db.Text
  status          String     @default("PROVISIONING") // PROVISIONING | ACTIVE | FAILED | RETIRED
  healthCheckedAt DateTime?

  launchCodes     AppLaunchCode[]
  runtimeSessions AppRuntimeSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([appReleaseId, environment])
  @@index([environment, status, createdAt])
}

// Per-Organization grants are derived from an approved release manifest and
// can be suspended independently without changing app-owned business data.
model AppCapabilityGrant {
  id                String          @id @default(cuid())
  organizationAppId String
  organizationApp   OrganizationApp @relation(fields: [organizationAppId], references: [id], onDelete: Cascade)
  capability        String
  status            String          @default("ACTIVE") // ACTIVE | SUSPENDED
  config            Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationAppId, capability])
  @@index([capability, status])
}

// Browser launch codes are short-lived, single-use and stored only as hashes.
model AppLaunchCode {
  id                String          @id @default(cuid())
  codeHash          String          @unique
  organizationAppId String
  organizationApp   OrganizationApp @relation(fields: [organizationAppId], references: [id], onDelete: Cascade)
  deploymentId      String
  deployment        AppDeployment   @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  userId            String
  returnPath        String
  expiresAt         DateTime
  consumedAt        DateTime?
  createdAt         DateTime        @default(now())

  @@index([organizationAppId, expiresAt])
  @@index([deploymentId, expiresAt])
}

// Independent runtimes receive an opaque bearer token. AppAI keeps only the
// hash and resolves identity/capability state on every introspection.
model AppRuntimeSession {
  id                String          @id @default(cuid())
  tokenHash         String          @unique
  organizationAppId String
  organizationApp   OrganizationApp @relation(fields: [organizationAppId], references: [id], onDelete: Cascade)
  deploymentId      String
  deployment        AppDeployment   @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  userId            String
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([organizationAppId, expiresAt])
  @@index([deploymentId, expiresAt])
}

// Metadata and authorization boundary for private native-app files. The Blob
// URL is never exposed to clients; downloads are streamed through an
// authenticated AppAI route.
model PrivateAsset {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appType         String
  pathname        String       @unique
  originalName    String
  contentType     String
  sizeBytes       Int
  status          String       @default("ACTIVE") // ACTIVE | DELETE_PENDING | DELETED
  createdByUserId String
  deletedByUserId String?
  deletedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, appType, status])
  @@index([organizationId, createdAt])
}

// Organization-local counters keep permanent customer numbers and monthly
// job-site display codes concurrency-safe without exposing Organization
// selection to clients.
model SimpleshopSequence {
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  key            String
  lastValue      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@id([organizationId, key])
}

model Customer {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerCode     Int
  name             String
  shortName        String?
  phone            String?
  address          String?      @db.Text
  paymentTermsDays Int?
  status           String       @default("ACTIVE") // ACTIVE | INACTIVE
  notes            String?      @db.Text

  jobSites     JobSite[]
  priceRecords PriceRecord[]
  contacts     CustomerContact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, customerCode])
  @@unique([organizationId, id])
  @@index([organizationId, status, name])
  @@index([organizationId, phone])
}

model JobSite {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerId     String
  customer       Customer     @relation(fields: [organizationId, customerId], references: [organizationId, id], onDelete: Restrict)
  name           String
  keyword        String?
  address        String?      @db.Text
  contactName    String?
  contactPhone   String?
  status         String       @default("ACTIVE") // ACTIVE | COMPLETED | INACTIVE
  notes          String?      @db.Text

  aliases      JobSiteAlias[]
  monthCodes   JobSiteMonthCode[]
  priceRecords PriceRecord[]
  contacts     CustomerContact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, id])
  @@unique([organizationId, customerId, id])
  @@index([organizationId, customerId, status])
  @@index([organizationId, name])
}

model JobSiteAlias {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerId      String
  jobSiteId       String
  jobSite         JobSite      @relation(fields: [organizationId, customerId, jobSiteId], references: [organizationId, customerId, id], onDelete: Cascade)
  alias           String
  normalizedAlias String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([organizationId, customerId, normalizedAlias])
  @@index([organizationId, jobSiteId])
}

model JobSiteMonthCode {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobSiteId      String
  jobSite        JobSite      @relation(fields: [organizationId, jobSiteId], references: [organizationId, id], onDelete: Cascade)
  month          String // YYYY-MM
  monthlyCode    Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, month, monthlyCode])
  @@unique([organizationId, month, jobSiteId])
  @@index([organizationId, jobSiteId, month])
}

model ItemCategory {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  normalizedName String
  dimensionMode  String       @default("NONE") // NONE | OPTIONAL | REQUIRED
  status         String       @default("ACTIVE") // ACTIVE | INACTIVE

  items Item[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, normalizedName])
  @@unique([organizationId, id])
  @@index([organizationId, status, name])
}

model Item {
  id                String        @id @default(cuid())
  organizationId    String
  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  categoryId        String?
  category          ItemCategory? @relation(fields: [organizationId, categoryId], references: [organizationId, id], onDelete: Restrict)
  itemCode          String
  canonicalName     String
  material          String?
  grade             String?
  dimensionMode     String        @default("NONE") // NONE | OPTIONAL | REQUIRED
  length            Decimal?      @db.Decimal(14, 4)
  width             Decimal?      @db.Decimal(14, 4)
  thickness         Decimal?      @db.Decimal(14, 4)
  dimensionUnit     String?
  defaultUnit       String
  calculationMethod String        @default("QUANTITY") // QUANTITY | CONVERSION | BOARD_MEASURE
  status            String        @default("ACTIVE") // ACTIVE | PENDING | INACTIVE
  notes             String?       @db.Text

  aliases      ItemAlias[]
  units        ItemUnit[]
  priceRecords PriceRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, itemCode])
  @@unique([organizationId, id])
  @@index([organizationId, status, canonicalName])
  @@index([organizationId, categoryId, status])
}

model ItemAlias {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itemId          String
  item            Item         @relation(fields: [organizationId, itemId], references: [organizationId, id], onDelete: Cascade)
  alias           String
  normalizedAlias String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([organizationId, normalizedAlias])
  @@index([organizationId, itemId])
}

model ItemUnit {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itemId         String
  item           Item         @relation(fields: [organizationId, itemId], references: [organizationId, id], onDelete: Cascade)
  unitCode       String
  label          String
  conversionRate Decimal?     @db.Decimal(18, 6)
  isDefault      Boolean      @default(false)
  status         String       @default("ACTIVE") // ACTIVE | INACTIVE
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, itemId, unitCode])
  @@index([organizationId, itemId, status])
}

model PriceRecord {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itemId         String
  item           Item         @relation(fields: [organizationId, itemId], references: [organizationId, id], onDelete: Restrict)
  priceType      String // PURCHASE | RETAIL | WHOLESALE | CUSTOMER | JOB_SITE
  customerId     String?
  customer       Customer?    @relation(fields: [organizationId, customerId], references: [organizationId, id], onDelete: Restrict)
  jobSiteId      String?
  jobSite        JobSite?     @relation(fields: [organizationId, jobSiteId], references: [organizationId, id], onDelete: Restrict)
  unitCode       String
  amount         Decimal      @db.Decimal(18, 4)
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  status         String       @default("ACTIVE") // ACTIVE | INACTIVE
  notes          String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, itemId, priceType, effectiveFrom])
  @@index([organizationId, customerId, status])
  @@index([organizationId, jobSiteId, status])
}

model CustomerContact {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerId      String
  customer        Customer     @relation(fields: [organizationId, customerId], references: [organizationId, id], onDelete: Restrict)
  jobSiteId       String?
  jobSite         JobSite?     @relation(fields: [organizationId, jobSiteId], references: [organizationId, id], onDelete: Restrict)
  contactType     String // PHONE | MESSAGE | VISIT | QUOTE | NOTE
  occurredAt      DateTime
  subject         String?
  notes           String       @db.Text
  createdByUserId String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId, customerId, occurredAt])
  @@index([organizationId, jobSiteId, occurredAt])
}

// Generic usage log for interactive tools (any connector), replacing
// per-tool tables. See docs/interactive-tools-architecture.md.
model UsageEvent {
  id             String        @id @default(cuid())
  connector      String
  userId         String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  action         String
  meta           Json?
  createdAt      DateTime      @default(now())

  @@index([connector, userId, createdAt])
  @@index([connector, createdAt])
  @@index([connector, organizationId, createdAt])
}
