generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ===== NextAuth.js Models =====

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("USER") // USER | ADMIN

  accounts Account[]
  sessions Session[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===== Business Models =====

model Organization {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text
  logoUrl     String?
  website     String?
  email       String?

  plan String @default("FREE")

  users   User[]
  apiKeys ApiKey[]
  pages   HostedPage[]
  apps    App[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiKey {
  id             String       @id @default(cuid())
  keyHash        String       @unique
  keyPrefix      String
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)

  createdAt DateTime @default(now())
}

model HostedPage {
  id             String       @id @default(cuid())
  slug           String
  locale         String       @default("en") // BCP 47: "en", "ja", "zh-CN", "ko", etc.
  isDefault      Boolean      @default(false) // Only one locale per slug should be true
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  template  String @default("APP_LANDING")
  title     String
  tagline   String?
  heroImage   String?
  headerLogo  String?
  content     Json

  privacyPolicy  String? @db.Text
  termsOfService String? @db.Text

  metaTitle       String?
  metaDescription String?
  ogImage         String?

  customCss   String? @db.Text
  themeColor          String? @default("#000000")
  themeColorSecondary String?
  fontFamily          String?
  darkMode            Boolean @default(false)
  isPublished         Boolean @default(false)

  customDomain String? @unique

  // Multi-page sites: parentSlug=null means root page; otherwise this is a child
  // page of (organizationId, parentSlug). Only one level of nesting is allowed —
  // child pages cannot themselves have children. URL: /p/{parentSlug}/{slug}.
  parentSlug String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, locale])
  @@index([organizationId, parentSlug, slug])
}

// RFC 8628 OAuth Device Authorization Grant
model DeviceCode {
  id             String   @id @default(cuid())
  deviceCode     String   @unique   // High-entropy (256-bit), used by CLI to poll
  userCode       String             // Short code "WDJB-MJHT", shown to user
  status         String   @default("pending") // pending | authorized | denied | expired | consumed
  apiKey         String?            // Plaintext key, cleared after consumed
  organizationId String?
  interval       Int      @default(5) // Polling interval in seconds, increases on slow_down
  lastPolledAt   DateTime?          // Server-side rate limiting for polling
  expiresAt      DateTime
  createdAt      DateTime @default(now())
}

model PageView {
  id        String   @id @default(cuid())
  pageId    String
  slug      String
  locale    String
  orgId     String
  ipHash    String
  country   String?
  referrer  String?  @db.Text
  createdAt DateTime @default(now())

  @@index([pageId, createdAt])
  @@index([orgId, createdAt])
  @@index([createdAt])
}

model App {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  tagline     String
  description String   @db.Text
  category    String   @default("OTHER")
  tags        String[] @default([])

  url        String?
  repoUrl    String?
  iosUrl     String?
  androidUrl String?

  logoUrl     String?
  screenshots String[] @default([])

  hostedPageSlug String? @unique

  isApproved Boolean @default(false)
  isFeatured Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
